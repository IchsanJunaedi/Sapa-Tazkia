{
  "private": true,
  "description": "Root package — Husky pre-commit hooks only. App code lives in backend/ and frontend/.",
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0"
  },
  "lint-staged": {
    "backend/src/**/*.js": [
      "eslint --fix -c backend/.eslintrc.js"
    ],
    "frontend/src/**/*.{js,jsx}": [
      "eslint --fix"
    ]
  }
}
