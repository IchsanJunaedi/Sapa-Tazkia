{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "seed": "node prisma/seed.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "reset:redis": "node reset-redis.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:api": "jest --forceExit --detectOpenHandles --testPathPattern=tests/(api|integration)",
    "test:unit": "jest --forceExit --detectOpenHandles --testPathPattern=tests/unit",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "coverage:merge": "node scripts/merge-coverage.js",
    "coverage:all": "npm run test:coverage && npm run test:e2e && npm run coverage:merge",
    "lint": "eslint src/ --ext .js",
    "lint:fix": "eslint src/ --ext .js --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.19.0",
    "@qdrant/js-client-rest": "^1.16.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "express-validator": "^7.3.0",
    "faiss-node": "^0.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.10",
    "openai": "^4.104.0",
    "otplib": "^13.3.0",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^2.4.2",
    "request-ip": "^3.3.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@playwright/test": "^1.48.0",
    "babel-jest": "^30.3.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "jest-junit": "^17.0.0",
    "monocart-coverage-reports": "^2.12.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2"
  }
}
