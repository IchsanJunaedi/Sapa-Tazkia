# backend/.env.test.example
# Copy to .env.test and fill with your local test values.
# The test suite auto-loads .env.test (see tests/setup.js).
#
# DO NOT commit the real .env.test — it's gitignored.

NODE_ENV=test

# MySQL test database (spin up via `docker-compose up -d mysql` or CI services)
DATABASE_URL="mysql://root:testpassword@127.0.0.1:3306/sapa_tazkia_test"

# Redis (required for rate limit & session tests)
REDIS_URL=redis://127.0.0.1:6379

# Auth secrets (dummy — at least 32 chars)
JWT_SECRET=ci-test-jwt-secret-32-chars-long-x
JWT_REFRESH_SECRET=ci-test-refresh-secret-32-chars-x
SESSION_SECRET=ci-test-session-secret-32-chars-xx

# OpenAI — only needed for tests that actually hit the AI API.
# Use a dummy value for unit tests; mock the module in integration tests.
OPENAI_API_KEY=sk-test-dummy-not-used-in-unit-tests

# Disable rate limiting so parallel test runs don't throttle each other.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEBUG=false

# Frontend URL (used by CORS and email templates)
FRONTEND_URL=http://localhost:3000

# E2E (Playwright)
E2E_BASE_URL=http://localhost:3100
E2E_TANYA_PATH=/chat/new
E2E_QUESTION_INPUT=[data-testid="pertanyaan-input"]
E2E_SUBMIT_BUTTON=[data-testid="submit-tanya"]
E2E_ANSWER_TEXT=[data-testid="jawaban-text"]

# tests/api/qa.test.js — override these to point at real endpoint/model
# TANYA_ENDPOINT=/api/guest/chat
# TANYA_MODEL_KEY=conversation
# TANYA_UNIQUE_FIELD=id

E2E_LOGIN_NIM=241572010024
E2E_LOGIN_PASSWORD=tazkia123